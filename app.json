{
  "expo": {
    "name": "Calculadora de obra",
    "slug": "calculadora-cielos",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/plan.png",
    "scheme": "calculadoracielos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/plan.png",
        "monochromeImage": "./assets/images/plan.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.manuelpana10.calculadoracielos"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/plan.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/plan.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ecaf4f88-e725-4da4-ae65-0975899f260a"
      }
    },
    "owner": "manuelpana10"
  }
}
